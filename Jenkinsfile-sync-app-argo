pipeline {
    agent any

    stages {
        stage('Execute sync app-argocd') {
            steps {
                sh '''
                    pwd
                    kubectl apply -f argoCD/argo-application.yaml


                '''
            }
        }
        stage('synchronization settings') {
            steps {
                sh '''
                    pwd
                    kubectl replace -n argocd -f https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml
                    kubectl rollout restart statefulset argocd-application-controller -n argocd
                    kubectl auth can-i list appprojects.argoproj.io \
                      --as system:serviceaccount:argocd:argocd-application-controller
                '''
            }
        }
    }
    post {
        success {
            echo "Sincronizacion app - argocd realizada correctamente."
        }
        cleanup {
            cleanWs() // Buena práctica: dejar el workspace limpio
        }
    }
}

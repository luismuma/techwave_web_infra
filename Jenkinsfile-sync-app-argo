pipeline {
    agent any

    stages {
        stage('Execute sync app-argocd-green') {
            steps {
                sh '''
                    pwd
                    kubectl apply -f argoCD/argo-application-green.yaml
                '''
            }
        }
        stage('Execute sync app-argocd-blue') {
            steps {
                sh '''
                    pwd
                    kubectl apply -f argoCD/argo-application-blue.yaml
                '''
            }
        }
    }
    post {
        success {
            echo "Sincronizacion app - argocd realizada correctamente."
        }
        cleanup {
            cleanWs() // Buena práctica: dejar el workspace limpio
        }
    }
}
